<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>multigit</id>
    <version>1.7.1</version>
    <title>Multigit</title>
    <authors>Philippe Fremy</authors>
    <owners>IDEMIA</owners>
    <projectUrl>https://github.com/idemia/multigit</projectUrl>
    <packageSourceUrl>https://github.com/idemia/multigit</packageSourceUrl>
    <docsUrl>https://github.com/idemia/multigit#readme</docsUrl>
    <bugTrackerUrl>https://github.com/idemia/multigit/issues</bugTrackerUrl>
    <licenseUrl>https://github.com/idemia/multigit/blob/main/LICENSE.txt</licenseUrl>
    <iconUrl>https://cdn.jsdelivr.net/gh/idemia/multigit@main/images/multigit-logo.png</iconUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <summary>Graphical tool for multi-repository Git projects.</summary>
    <description>Multigit is a graphical tool for working with projects composed of multiple Git repositories. This Chocolatey package embeds the official Windows installer generated from this repository.</description>
    <releaseNotes>https://github.com/idemia/multigit/blob/main/CHANGELOG.md</releaseNotes>
    <tags>git gui repositories qt pyside6</tags>
    <copyright>Copyright IDEMIA</copyright>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>

